generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AiModel {
  id             Int              @id @default(autoincrement())
  title          String
  category       String
  indications    String
  modality       String
  bodyPart       String
  fda            Boolean          @default(true)
  fdaUrl         String           @unique
  endpointUrl    String?          @unique
  cover          String?
  deliveryTime   Int?
  desc           String
  price          Int
  subscription   Boolean          @default(false)
  payPerClick    Boolean          @default(false)
  revisionNumber Int?
  sales          Int
  starFrequency  Int?
  totalStars     Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  userId         Int
  User           User             @relation(fields: [userId], references: [id],onDelete: Cascade)
  AiModelFeature AiModelFeature[]
  AiModelImage   AiModelImage[]
  AiModelMetrics AiModelMetrics[]
  Order          Order[]
  Review         Review[]

  @@index([userId])
}

model AiModelFeature {
  id        Int     @id @default(autoincrement())
  feature   String
  aiModelId Int
  AiModel   AiModel @relation(fields: [aiModelId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
}

model AiModelImage {
  id        Int     @id @default(autoincrement())
  imageUrl  String
  aiModelId Int
  AiModel   AiModel @relation(fields: [aiModelId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
}

model AiModelMetrics {
  id         Int     @id @default(autoincrement())
  metric     String
  value      Float
  aiModelId  Int
  metricsUrl String?
  AiModel    AiModel @relation(fields: [aiModelId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
}

model Contact {
  id      Int    @id @default(autoincrement())
  message String
  name    String
  number  String
  userId  Int
  User    User   @relation(fields: [userId], references: [id],onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id                                  Int       @id @default(autoincrement())
  lastMessage                         String?
  unReadMsg                           Int?
  copyFor                             Int?
  readByClient                        Boolean
  readByDeveloper                     Boolean
  createdAt                           DateTime  @default(now())
  updatedAt                           DateTime
  clientId                            Int
  developerId                         Int
  User_Conversation_clientIdToUser    User      @relation("Conversation_clientIdToUser", fields: [clientId], references: [id],onDelete: Cascade)
  User_Conversation_developerIdToUser User      @relation("Conversation_developerIdToUser", fields: [developerId], references: [id],onDelete: Cascade)
  Message                             Message[]

  @@index([clientId])
  @@index([developerId])
}

model Message {
  id             Int          @id @default(autoincrement())
  desc           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  userId         Int
  conversationId Int
  Conversation   Conversation @relation(fields: [conversationId], references: [id],onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id],onDelete: Cascade)

  @@index([conversationId])
  @@index([userId])
}

model Notification {
  id                                  Int       @id @default(autoincrement())
  actionDesc                          String
  unRead                              Boolean
  createdAt                           DateTime  @default(now())
  to                                  Int
  from                                Int
  actionLink                          String
  @@index([to])
}

model Order {
  id                           Int      @id @default(autoincrement())
  aiModelId                    Int
  img                          String
  isCompleted                  Boolean  @default(false)
  payment_intent               String
  price                        Int
  developerId                  Int
  title                        String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  clientId                     Int
  AiModel                      AiModel  @relation(fields: [aiModelId], references: [id],onDelete: Cascade)
  User_Order_clientIdToUser    User     @relation("Order_clientIdToUser", fields: [clientId], references: [id],onDelete: Cascade)
  User_Order_developerIdToUser User     @relation("Order_developerIdToUser", fields: [developerId], references: [id],onDelete: Cascade)
  Review                       Review?

  @@index([aiModelId])
  @@index([clientId])
  @@index([developerId])
}

model Review {
  id        Int      @id @default(autoincrement())
  desc      String
  star      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clientId  Int
  aiModelId Int
  orderId   Int      @unique
  AiModel   AiModel  @relation(fields: [aiModelId], references: [id],onDelete: Cascade)
  User      User     @relation(fields: [clientId], references: [id],onDelete: Cascade)
  Order     Order    @relation(fields: [orderId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
  @@index([clientId])
}

enum UserRole {
  ADMIN
  DEVELOPER
  CLIENT
}

model User {
  id                                          Int            @id @default(autoincrement())
  customId                                    String         @unique
  isActive                                    Boolean        @default(true)
  role                                        UserRole
  first_name                                  String?
  last_name                                   String?
  email                                       String         @unique
  org_phone                                   String         @unique
  org_username                                String         @unique
  password                                    String
  org_name                                    String         @unique
  org_desc                                    String
  country                                     String?
  logoUrl                                     String?
  avatar                                      String?
  org_aet                                     String?        @unique
  org_ipAddress                               String?        @unique
  failed_attempts                             Int            @default(0)
  lockup                                      DateTime?
  password_change                             DateTime?      @default(now())
  total_orders                                Int?
  createdAt                                   DateTime       @default(now())
  updatedAt                                   DateTime       @updatedAt
  AiModel                                     AiModel[]
  Contact                                     Contact[]
  Conversation_Conversation_clientIdToUser    Conversation[] @relation("Conversation_clientIdToUser")
  Conversation_Conversation_developerIdToUser Conversation[] @relation("Conversation_developerIdToUser")
  Message                                     Message[]
  Order_Order_clientIdToUser                  Order[]        @relation("Order_clientIdToUser")
  Order_Order_developerIdToUser               Order[]        @relation("Order_developerIdToUser")
  Review                                      Review[]
  UserDetails                                 UserDetails[]

  rule_id   Int
  target_id Int
  module_id Int
}


model EmailToken {
  id                                          Int            @id @default(autoincrement())
  email                                       String         @unique
  emailToken                                  String
  isVerified                                  Boolean?       @default(false)
  createdAt                                   DateTime       @default(now())
  expiresAt                                   DateTime?
}

model Module {
  module_id          Int      @id @default(autoincrement())
  name               String
  docker_tag         String?
  docker_tag_type    String?
  additional_volumes String?
  environment        String?
  docker_arguments   String?
  settings           Json
  contact            String?
  comment            String?
  constraints        String?
  container_type     String?
  resources          String?
  requires_root      Boolean?

  @@index([module_id], name: "idx_module_id")
}

model Rule {
  rule_id                                    Int     @id @default(autoincrement())
  rule                                       String
  name                                       String
  target                                     String
  disabled                                   Boolean
  fallback                                   Boolean
  contact                                    String
  comment                                    String
  tags                                       String
  // action                                     RuleAction
  // action_trigger                             RuleActionTrigger
  // study_trigger_condition                    RuleStudyTriggerCondition
  study_trigger_series                       String
  // priority                                   RulePriority
  processing_module                          Json
  processing_settings                        Json
  processing_retain_images                   Boolean
  notification_email                         String
  notification_webhook                       String
  notification_payload                       String
  notification_payload_body                  String
  notification_email_body                    String
  notification_email_type                    String
  notification_trigger_reception             Boolean
  notification_trigger_completion            Boolean
  notification_trigger_completion_on_request Boolean
  notification_trigger_error                 Boolean

  @@index([rule_id], name: "idx_rule_id")
}

model DicomTarget {
  target_type String  @unique
  target_id   Int     @id @default(autoincrement())
  ip          String
  port        String
  aet_target  String
  aet_source  String?
  contact     String?
  comment     String?

  @@index([target_id], name: "idx_target_id")
}

model UserDetails {
  id             Int       @id @default(autoincrement())
  name           String?
  customId       String?
  role           UserRole?
  email          String?
  password       String?
  isAdmin        Boolean?
  changePassword Boolean?
  permissions    Json?
  targets        Json?
  rules          Json?
  modules        Json?

  // Relation to User
  userId Int
  user   User @relation(fields: [userId], references: [id],onDelete: Cascade)

  @@index([userId], name: "idx_user_id")
}

model AlembicVersion {
  versionNum String @id
}

model DicomFile {
  id        Int      @id @default(autoincrement())
  time      DateTime
  filename  String
  fileUid   String
  seriesUid String
}

model DicomSeries {
  id                        Int      @id @default(autoincrement())
  time                      DateTime
  seriesUid                 String   @unique
  tagPatientName            String
  tagPatientId              String
  tagAccessionNumber        String
  tagSeriesNumber           String
  tagStudyId                String
  tagPatientBirthDate       String
  tagPatientSex             String
  tagAcquisitionDate        String
  tagAcquisitionTime        String
  tagModality               String
  tagBodyPartExamined       String
  tagStudyDescription       String
  tagSeriesDescription      String
  tagProtocolName           String
  tagCodeValue              String
  tagCodeMeaning            String
  tagSequenceName           String
  tagScanningSequence       String
  tagSequenceVariant        String
  tagSliceThickness         String
  tagContrastBolusAgent     String
  tagReferringPhysicianName String
  tagManufacturer           String
  tagManufacturerModelName  String
  tagMagneticFieldStrength  String
  tagDeviceSerialNumber     String
  tagSoftwareVersions       String
  tagStationName            String
  studyUid                  String
}

model DicomSeriesMap {
  idFile   Int  @id
  idSeries Int? @unique
}

model FileEvent {
  id        Int      @id @default(autoincrement())
  time      DateTime
  dicomFile Int
  event     Int
}

model MercureEvent {
  id          Int      @id @default(autoincrement())
  time        DateTime
  sender      String
  event       String
  severity    Int
  description String
}

model ProcessorLog {
  id         Int      @id @default(autoincrement())
  taskId     Int?
  moduleName String
  logs       String
  time       DateTime
  task       Task?    @relation(fields: [taskId], references: [id],onDelete: Cascade)
}

model ProcessorOutput {
  id       Int      @id @default(autoincrement())
  time     DateTime @default(now())
  taskId   Int?
  taskAcc  String
  taskMrn  String
  module   String
  index    Int
  settings Json
  output   Json
  task     Task?    @relation(fields: [taskId], references: [id],onDelete: Cascade)
}

model SeriesSequenceData {
  uid  String @id
  data Json
}

model TaskEvent {
  id              Int      @id @default(autoincrement())
  time            DateTime
  sender          String
  event           String
  seriesUid       String
  fileCount       Int
  target          String
  info            String
  taskId          String
  clientTimestamp Float
}

model Task {
  id        Int               @id @default(autoincrement())
  time      DateTime
  seriesUid String
  studyUid  String
  data      Json
  parentId  String?
  logs      ProcessorLog[]
  outputs   ProcessorOutput[]
}

model Test {
  id         Int      @id @default(autoincrement())
  typeOfTest String
  taskId     String
  timeBegin  DateTime
  timeEnd    DateTime
  status     String
  data       Json
  ruleType   String
}

model WebGuiEvent {
  id          Int      @id @default(autoincrement())
  time        DateTime
  sender      String
  event       String
  user        String
  description String
}