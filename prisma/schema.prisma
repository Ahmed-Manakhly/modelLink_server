generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AiModel {
  id             Int              @id @default(autoincrement())
  title          String
  category       String
  indications    String
  modality       String
  bodyPart       String
  fda            Boolean          @default(true)
  fdaUrl         String           @unique
  endpointUrl    String?          @unique
  cover          String?
  deliveryTime   Int?
  desc           String
  price          Int
  subscription   Boolean          @default(false)
  payPerClick    Boolean          @default(false)
  revisionNumber Int?
  sales          Int
  starFrequency  Int?
  totalStars     Int
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  userId         String
  User           User             @relation(fields: [userId], references: [id],onDelete: Cascade)
  AiModelFeature AiModelFeature[]
  AiModelImage   AiModelImage[]
  AiModelMetrics AiModelMetrics[]
  Order          Order[]
  Review         Review[]

  @@index([userId])
}

model AiModelFeature {
  id        Int     @id @default(autoincrement())
  feature   String
  aiModelId Int
  AiModel   AiModel @relation(fields: [aiModelId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
}

model AiModelImage {
  id        Int     @id @default(autoincrement())
  imageUrl  String
  aiModelId Int
  AiModel   AiModel @relation(fields: [aiModelId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
}

model AiModelMetrics {
  id         Int     @id @default(autoincrement())
  metric     String
  value      Float
  aiModelId  Int
  metricsUrl String?
  AiModel    AiModel @relation(fields: [aiModelId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
}

model Contact {
  id      Int    @id @default(autoincrement())
  message String
  name    String
  number  String
  userId  String
  User    User   @relation(fields: [userId], references: [id],onDelete: Cascade)

  @@index([userId])
}

model Conversation {
  id                                  Int       @id @default(autoincrement())
  lastMessage                         String?
  unReadMsg                           Int?
  copyFor                             String?
  readByClient                        Boolean
  readByDeveloper                     Boolean
  createdAt                           DateTime  @default(now())
  updatedAt                           DateTime
  clientId                            String
  developerId                         String
  User_Conversation_clientIdToUser    User      @relation("Conversation_clientIdToUser", fields: [clientId], references: [id],onDelete: Cascade)
  User_Conversation_developerIdToUser User      @relation("Conversation_developerIdToUser", fields: [developerId], references: [id],onDelete: Cascade)
  Message                             Message[]

  @@index([clientId])
  @@index([developerId])
}

model Message {
  id             Int          @id @default(autoincrement())
  desc           String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  userId         String
  conversationId Int
  Conversation   Conversation @relation(fields: [conversationId], references: [id],onDelete: Cascade)
  User           User         @relation(fields: [userId], references: [id],onDelete: Cascade)

  @@index([conversationId])
  @@index([userId])
}

model Notification {
  id                                  Int       @id @default(autoincrement())
  actionDesc                          String
  unRead                              Boolean
  createdAt                           DateTime  @default(now())
  to                                  String
  from                                String
  actionLink                          String
  @@index([to])
}

model Order {
  id                           Int      @id @default(autoincrement())
  aiModelId                    Int
  img                          String
  isCompleted                  Boolean  @default(false)
  payment_intent               String
  price                        Int
  developerId                  String
  title                        String
  createdAt                    DateTime @default(now())
  updatedAt                    DateTime @updatedAt
  clientId                     String
  AiModel                      AiModel  @relation(fields: [aiModelId], references: [id],onDelete: Cascade)
  User_Order_clientIdToUser    User     @relation("Order_clientIdToUser", fields: [clientId], references: [id],onDelete: Cascade)
  User_Order_developerIdToUser User     @relation("Order_developerIdToUser", fields: [developerId], references: [id],onDelete: Cascade)
  Review                       Review?

  @@index([aiModelId])
  @@index([clientId])
  @@index([developerId])
}

model Review {
  id        Int      @id @default(autoincrement())
  desc      String
  star      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  clientId  String
  aiModelId Int
  orderId   Int      @unique
  AiModel   AiModel  @relation(fields: [aiModelId], references: [id],onDelete: Cascade)
  User      User     @relation(fields: [clientId], references: [id],onDelete: Cascade)
  Order     Order    @relation(fields: [orderId], references: [id],onDelete: Cascade)

  @@index([aiModelId])
  @@index([clientId])
}

enum UserRole {
  ADMIN
  EMPLOYEE
  DEVELOPER
  CLIENT
}

model User {
  id                                          String         @id @default(cuid())
  customId                                    String         @unique
  isActive                                    Boolean        @default(true)
  role                                        UserRole
  first_name                                  String?
  last_name                                   String?
  email                                       String         @unique
  org_phone                                   String?
  org_username                                String         @unique
  password                                    String
  org_name                                    String?
  org_desc                                    String?
  country                                     String?
  logoUrl                                     String?
  avatar                                      String?
  org_aet                                     String?
  org_ipAddress                               String?
  failed_attempts                             Int            @default(0)
  lockup                                      DateTime?
  password_change                             DateTime?      @default(now())
  total_orders                                Int?
  createdAt                                   DateTime       @default(now())
  updatedAt                                   DateTime       @updatedAt
  AiModel                                     AiModel[]
  Contact                                     Contact[]
  Conversation_Conversation_clientIdToUser    Conversation[] @relation("Conversation_clientIdToUser")
  Conversation_Conversation_developerIdToUser Conversation[] @relation("Conversation_developerIdToUser")
  Message                                     Message[]
  Order_Order_clientIdToUser                  Order[]        @relation("Order_clientIdToUser")
  Order_Order_developerIdToUser               Order[]        @relation("Order_developerIdToUser")
  Review                                      Review[]

}


model EmailToken {
  id                                          Int            @id @default(autoincrement())
  email                                       String         @unique
  emailToken                                  String
  isVerified                                  Boolean?       @default(false)
  createdAt                                   DateTime       @default(now())
  expiresAt                                   DateTime?
}
