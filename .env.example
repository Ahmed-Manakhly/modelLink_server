# --- Database (Docker via start-db-only.dev.sh) ---
POSTGRES_USER=modellink
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=modellink
PGDATA=/var/lib/postgresql/data
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change_me

NODE_ENV=development
PORT=8000
DATABASE_URL=postgresql://modellink:change_me_strong_password@localhost:5432/modellink

# --- Bootstrap admin (created on first start) ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=ChangeMe123!@#
ADMIN_NAME=Admin

# --- Email (use Mailtrap or Gmail app password in dev) ---
SMTP_EMAIL=you@example.com
SMTP_PASSWORD=your_smtp_password
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587

# --- Auth / crypto ---
PASSWORD_COMPLEXITY=password must be at least 12 characters long and contain at least one uppercase letter, one lowercase letter, one digit and one special character !
ACCESS_SECRET_STR=generate_random_32_plus_chars
JWT_SECRET=generate_another_random_32_chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef
OTP_EXPIRATION=5
ACCESS_TOKEN_EXPIRATION=2700000

# --- Files ---
LOG_DIR=./logs
PUBLIC_DIR=public
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp,application/pdf

# --- Portfolio demo (no real Stripe required in development) ---
MARKETPLACE_DEMO=true

# --- Email (skipped when MARKETPLACE_DEMO=true or EMAIL_SEND_DISABLED=true) ---
# EMAIL_SEND_DISABLED=true

# --- Stripe (production only; optional in dev when MARKETPLACE_DEMO=true) ---
# App code uses STRIPE and STRIPE_WEBHOOK_SECRET. envValidator checks STRIPE_SECRET_KEY in production.
# STRIPE=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_SECRET_KEY=sk_test_...

# --- Production only ---
# CORS_ORIGINS=https://your-frontend.example.com
# CLIENT_URL=https://your-frontend.example.com
